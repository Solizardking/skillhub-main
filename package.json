{
  "name": "@x402solana/skills",
  "version": "0.1.1",
  "description": "Catalog and one-shot installer for Solizardking agent skills (hub + one-shot CLI).",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Solizardking/skills.git"
  },
  "homepage": "https://github.com/Solizardking/skills#readme",
  "bugs": {
    "url": "https://github.com/Solizardking/skills/issues"
  },
  "keywords": [
    "skills",
    "agent-skills",
    "installer",
    "solizardking",
    "skillhub",
    "clawd",
    "agents",
    "x402solana"
  ],
  "bin": {
    "skills": "bin/skills.mjs"
  },
  "files": [
    "bin",
    "catalog.json",
    "skills",
    "README.md",
    "HUB.md",
    "DOMAINS.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepack": "node scripts/npm-pack-exclude.mjs hide",
    "postpack": "node scripts/npm-pack-exclude.mjs restore",
    "build": "node scripts/build-catalog.mjs",
    "build:catalog": "node scripts/build-catalog.mjs",
    "skills:docs": "node scripts/build-catalog.mjs",
    "check": "node scripts/build-catalog.mjs --check",
    "scanner:scan": "node scanner/bin/scan-skills.mjs",
    "scanner:scan:all": "node scanner/bin/scan-skills.mjs --all-local",
    "scanner:serve": "python3 -m http.server 8877 --bind 127.0.0.1 --directory scanner/public",
    "smoke": "node scripts/smoke-test-skills.mjs",
    "test:premiere": "node scripts/test-premiere-skills.mjs",
    "test:pack": "node scripts/test-npm-pack.mjs",
    "publish:onchain": "node scripts/publish-onchain.mjs",
    "publish:agentregistry": "bash scripts/publish-to-agentregistry.sh",
    "publish:agentregistry:dry": "bash scripts/publish-to-agentregistry.sh --dry-run",
    "publish:agentregistry:onchain": "node scripts/sync-onchain-agentregistry.mjs",
    "publish:agentregistry:onchain:dry": "node scripts/sync-onchain-agentregistry.mjs --dry-run",
    "publish:agentregistry:onchain:plan": "node scripts/sync-onchain-agentregistry.mjs --plan-only",
    "relay": "node scripts/skill-relay.mjs",
    "relay:watch": "node scripts/skill-relay.mjs --watch",
    "relay:fast": "node scripts/skill-relay.mjs --fast",
    "relay:push": "node scripts/skill-relay.mjs --commit --push",
    "relay:upload": "node scripts/upload-relay-server.mjs",
    "relay:upload:dev": "SKILLHUB_PAYMENT_NETWORK=devnet node scripts/upload-relay-server.mjs",
    "skills:process": "node scripts/skills-process.mjs",
    "skills:watch": "node scripts/skills-process.mjs --watch",
    "ledger:export": "node scripts/export-public-ledger.mjs",
    "test": "node scripts/build-catalog.mjs --check && node scripts/smoke-test-skills.mjs && node bin/skills.mjs list --json >/dev/null && node scripts/test-premiere-skills.mjs && node scripts/test-npm-pack.mjs && node scripts/test-skills-process.mjs && node scripts/test-skill-relay-onchain.mjs",
    "test:skills-process": "node scripts/test-skills-process.mjs",
    "test:relay-onchain": "node scripts/test-skill-relay-onchain.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@irys/upload": "^0.0.15",
    "@irys/upload-solana": "^0.1.8",
    "@solana/web3.js": "^1.98.4"
  }
}
